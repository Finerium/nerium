# NERIUM backend env example. Copy to .env for local development.
# All vars read by src/backend/config.py via pydantic-settings with prefix NERIUM_.
# Sensitive values MUST NOT be committed. .env is gitignored.

# Environment discriminator.
# Allowed: development | staging | production
NERIUM_ENV=development

# Version tag, surfaced via OpenAPI info.version and obs resource attribute.
NERIUM_VERSION=0.1.0

# Logging
NERIUM_LOG_LEVEL=INFO

# Secret for signing session cookies and CSRF tokens.
# Generate via: python -c "import secrets; print(secrets.token_urlsafe(64))"
NERIUM_SECRET_KEY=dev-only-secret-do-not-use-in-production-generate-your-own

# Postgres 16. No pgbouncer at submission.
# Pool min 2, max 20 per postgres_multi_tenant.contract.md Section 4.1.
NERIUM_DATABASE_URL=postgresql://nerium_api:nerium_api_pw@localhost:5432/nerium
NERIUM_DATABASE_POOL_MIN_SIZE=2
NERIUM_DATABASE_POOL_MAX_SIZE=20
NERIUM_DATABASE_STATEMENT_CACHE_SIZE=100
NERIUM_DATABASE_COMMAND_TIMEOUT_SECONDS=30.0

# Alembic uses a separate role with BYPASSRLS. See postgres_multi_tenant.contract.md Section 4.3.
NERIUM_DATABASE_MIGRATION_URL=postgresql://nerium_migration:nerium_migration_pw@localhost:5432/nerium

# Redis 7. Single-box, self-hosted per redis_session.contract.md Section 3.
NERIUM_REDIS_URL=redis://:nerium_app_pw@localhost:6379/0
NERIUM_REDIS_MAX_CONNECTIONS=50

# HTTP server
NERIUM_HTTP_HOST=0.0.0.0
NERIUM_HTTP_PORT=3100

# Trusted hosts for TrustedHostMiddleware (comma separated).
# Prod should include the canonical domain and subdomain wildcard.
NERIUM_TRUSTED_HOSTS=localhost,127.0.0.1,nerium.com,*.nerium.com

# CORS allowlist for credentialed requests. Exact origins, no wildcards.
NERIUM_CORS_ORIGINS=http://localhost:3100,http://localhost:3000,https://nerium.com,https://claude.ai

# Observability (Selene subsystem, optional in Session 1; required before prod)
NERIUM_OTEL_ENABLED=false
NERIUM_OTEL_ENDPOINT=
NERIUM_GRAFANA_OTLP_TOKEN=
NERIUM_GLITCHTIP_DSN=

# Anthropic (Kratos, Khronos consume; not used in Session 1 core)
NERIUM_ANTHROPIC_API_KEY=

# Feature flag overrides applied at boot (Hemera consumes; optional bootstrap)
NERIUM_HEMERA_BOOTSTRAP_BUILDER_LIVE=false
