# Observability environment variables.
# Owner: Selene (W1). Contract: docs/contracts/observability.contract.md.
#
# Append these entries to the project-level .env (gitignored). Example values
# shown as placeholders; replace with your Grafana Cloud Free and GlitchTip
# self-host values before boot.
#
# Ghaisan signup steps summary:
#   1. grafana.com/auth/sign-up  -> free tier (50 GB logs + 50 GB traces +
#      10k series metrics + 14-day retention + 3 users).
#   2. Create access policy with scopes: metrics:write, logs:write, traces:write.
#   3. Generate API token under that policy; write to ${GRAFANA_CLOUD_API_KEY_FILE}
#      as a single-line file (Alloy reads via local.file).
#   4. From the Grafana Cloud stack details page copy the Prometheus remote_write
#      endpoint and username (a numeric instance id), Loki push endpoint +
#      username, Tempo OTLP endpoint + username.
#   5. For GlitchTip: docker compose -f ops/glitchtip/docker-compose.glitchtip.yml up -d
#      then visit http://localhost:8000 -> create organisation + project ->
#      copy the DSN into GLITCHTIP_DSN.

# Core service identity
DEPLOYMENT_ENV=development
SERVICE_NAME=nerium-api
SERVICE_VERSION=0.1.0
LOG_LEVEL=INFO

# OpenTelemetry OTLP exporter (Grafana Cloud Tempo HTTP ingest).
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_TRACES_SAMPLER=parentbased_always_on
OTEL_TRACES_SAMPLER_ARG=1.0

# Grafana Cloud Alloy targets (ops/alloy/config.river reads these).
GRAFANA_CLOUD_PROM_URL=https://prometheus-prod-xx-prod-xx-xxxx.grafana.net/api/prom/push
GRAFANA_CLOUD_PROM_USERNAME=
GRAFANA_CLOUD_LOKI_URL=https://logs-prod-xxx.grafana.net/loki/api/v1/push
GRAFANA_CLOUD_LOKI_USERNAME=
GRAFANA_CLOUD_TEMPO_URL=https://tempo-prod-xx-prod-xx-xxxx.grafana.net/otlp
GRAFANA_CLOUD_TEMPO_USERNAME=
GRAFANA_CLOUD_API_KEY_FILE=/etc/alloy/grafana_cloud_api_key
NERIUM_API_METRICS_ADDR=nerium-api:8080

# GlitchTip self-host (ops/glitchtip/docker-compose.glitchtip.yml).
GLITCHTIP_DSN=
GLITCHTIP_DOMAIN=http://localhost:8000
GLITCHTIP_SECRET_KEY=
GLITCHTIP_POSTGRES_PASSWORD=
GLITCHTIP_EMAIL_URL=consolemail://
GLITCHTIP_FROM_EMAIL=noreply@nerium.local

# Sentry Cloud Developer fallback (5k events/mo free) if GlitchTip self-host
# breaks the Hetzner CX32 8 GB RAM budget. Leave empty until that trigger hits.
SENTRY_DSN=
